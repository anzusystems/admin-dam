#!/bin/bash
# Wrapper script used to run the specified command from argument in the application container
set -e

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"

cd "${PROJECT_ROOT}" || exit 1

function help() {
    echo -en "$(printf %q "${BASH_SOURCE[0]}") [COMMAND]...
    \nBash wrapper script used to run the specified command from argument in the application container.

    Examples:
        $(printf %q "${BASH_SOURCE[0]}") composer -n install
        $(printf %q "${BASH_SOURCE[0]}") bin/console cache:clear --env=prod
        $(printf %q "${BASH_SOURCE[0]}") bin/console messenger:setup-transports
    \n"
}

if [ $# -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    help
    exit 0
fi

if [ -f /.dockerenv ]; then
    exec "$@"
    exit
fi

bin/docker-compose exec core-dam "$@"
